# Placeholders uniquement — jamais de vraie valeur committee. Copier en
# `deploy/.env.staging` SUR LE VPS (a la main par Aymeric), jamais dans le
# repo, jamais dans une image. Donnees de test : secrets distincts de la prod,
# mais pas besoin d'une rigueur de generation aussi poussee.
#
# IMAGE_TAG n'est PAS dans ce fichier : injecte par le workflow CD au moment
# du deploiement (`IMAGE_TAG=<tag> docker compose ...`).

# --- PostgreSQL ---
POSTGRES_USER=story_tide
POSTGRES_PASSWORD=change-me-staging-password
POSTGRES_DB=story_tide
# DATABASE_URL n'est pas ici : construite dans compose.staging.yml a partir
# des trois variables POSTGRES_* ci-dessus.

# --- Authentification (Better Auth) ---
BETTER_AUTH_SECRET=change-me-at-least-32-characters-long
BETTER_AUTH_URL=https://staging.storytide.fr

# --- Stockage binaires (MinIO) ---
MINIO_ROOT_USER=story_tide
MINIO_ROOT_PASSWORD=change-me-staging-password
# S3_ACCESS_KEY/S3_SECRET_KEY de l'app/worker = MINIO_ROOT_USER/PASSWORD
# ci-dessus (construits dans compose.staging.yml).
S3_REGION=us-east-1
S3_BUCKET=story-tide-staging
