# Placeholders uniquement — jamais de vraie valeur committee. Copier en
# `deploy/.env.prod` SUR LE VPS (a la main par Aymeric), jamais dans le repo,
# jamais dans une image.
#
# IMAGE_TAG n'est PAS dans ce fichier : injecte par le workflow CD au moment
# du deploiement (`IMAGE_TAG=<tag> docker compose ...`), jamais fixe cote
# serveur — sinon deux sources de verite pour la version deployee.

# --- PostgreSQL ---
# Generer un mot de passe fort : `openssl rand -base64 32`
POSTGRES_USER=story_tide
POSTGRES_PASSWORD=change-me-strong-prod-password
POSTGRES_DB=story_tide
# DATABASE_URL n'est pas ici : construite dans compose.prod.yml a partir des
# trois variables POSTGRES_* ci-dessus (une seule source de verite).

# --- Authentification (Better Auth) ---
# Generer : `openssl rand -base64 32`
BETTER_AUTH_SECRET=change-me-at-least-32-characters-long
BETTER_AUTH_URL=https://storytide.fr

# --- Stockage binaires (MinIO) ---
# Generer un mot de passe fort : `openssl rand -base64 32`. Idealement une
# cle dediee a droits restreints plutot que le compte root MinIO (moindre
# privilege) — a revoir si MinIO expose un mecanisme de policy IAM utilise.
MINIO_ROOT_USER=story_tide
MINIO_ROOT_PASSWORD=change-me-strong-prod-password
# S3_ACCESS_KEY/S3_SECRET_KEY de l'app/worker = MINIO_ROOT_USER/PASSWORD
# ci-dessus (construits dans compose.prod.yml, meme convention que le dev).
# S3_REGION exigee par le SDK S3 (signature AWS SigV4) meme si MinIO ne route
# rien selon la region en mono-nœud.
S3_REGION=us-east-1
S3_BUCKET=story-tide-prod

# --- Let's Encrypt (stack Traefik partagee — voir deploy/traefik/.env.example) ---
# ACME_EMAIL n'est pas ici : c'est un fichier separe (deploy/traefik/.env),
# la stack Traefik est partagee entre staging et prod.

# --- Supervision (heartbeat de sauvegarde) ---
# URL fournie par la sonde externe (Better Stack) pour ce heartbeat precis.
# Optionnelle : absente ou vide, le service backup ne ping personne (aucun
# echec de sauvegarde declenche par ce defaut).
BACKUP_HEARTBEAT_URL=
