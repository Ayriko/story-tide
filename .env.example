# Environnement
NODE_ENV=development

# Base de donnees (PostgreSQL — docker-compose.dev.yml)
DATABASE_URL="postgresql://story_tide:story_tide@localhost:5432/story_tide?schema=public"

# Authentification (Better Auth)
BETTER_AUTH_SECRET="change-me-at-least-32-characters-long"
BETTER_AUTH_URL="http://localhost:3000"

# Stockage binaires (MinIO — docker-compose.dev.yml)
S3_ENDPOINT="localhost"
S3_PORT=9000
S3_USE_SSL=false
S3_REGION="us-east-1"
S3_ACCESS_KEY="story_tide"
S3_SECRET_KEY="change-me-story-tide"
S3_BUCKET="story-tide-dev"