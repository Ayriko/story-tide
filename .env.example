# Environnement
NODE_ENV=development

# Base de donnees (PostgreSQL — docker-compose.dev.yml)
DATABASE_URL="postgresql://story_tide:story_tide@localhost:5432/story_tide?schema=public"

# Authentification (Better Auth)
# BETTER_AUTH_SECRET est un secret a GENERER (ex. `openssl rand -base64 32`),
# jamais recupere. Valeur ci-dessous = placeholder dev uniquement ;
# en staging/prod, generer une valeur forte et ne jamais la committer.
BETTER_AUTH_SECRET="change-me-at-least-32-characters-long"
BETTER_AUTH_URL="http://localhost:3000"

# Stockage binaires (MinIO — docker-compose.dev.yml)
S3_ENDPOINT="localhost"
S3_PORT=9000
S3_USE_SSL=false
# S3_REGION est exigee par le SDK S3 (signature AWS SigV4), meme si MinIO ne
# route rien selon la region en mono-nœud : valeur arbitraire en dev, mais
# redevient significative en staging/prod avec OVH Object Storage (ex. "gra", "sbg").
S3_REGION="us-east-1"
# S3_ACCESS_KEY / S3_SECRET_KEY doivent correspondre a MINIO_ROOT_USER /
# MINIO_ROOT_PASSWORD dans docker-compose.dev.yml. Placeholder en dev ; a
# generer en staging/prod (idealement une cle dediee a droits restreints,
# pas le compte root MinIO — moindre privilege).
S3_ACCESS_KEY="story_tide"
S3_SECRET_KEY="change-me-story-tide"
S3_BUCKET="story-tide-dev"