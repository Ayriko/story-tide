# Environnement dedie au smoke Playwright (e2e/). Copier en .env.e2e (ignore
# par git) — jamais la base de dev : base et port distincts.

NODE_ENV=development

# Base DEDIEE, sur le meme conteneur Postgres dev (docker-compose.dev.yml,
# port 5432) : e2e/global-setup.ts la cree si absente et la remet a zero
# (DROP/CREATE SCHEMA + migrate deploy) avant chaque run. La base de dev
# "story_tide" n'est jamais ouverte par le smoke.
DATABASE_URL="postgresql://story_tide:story_tide@localhost:5432/story_tide_e2e?schema=public"

# Secret placeholder (>=32 caracteres), jamais reutilise en staging/prod.
BETTER_AUTH_SECRET="e2e-placeholder-secret-at-least-32-characters"
# Port dedie : n'entre pas en conflit avec un `next dev` de dev sur :3000.
BETTER_AUTH_URL="http://localhost:3100"

# S3_* : credentials ROOT reelles (KAN-16, upload d'images exerce en e2e) -
# meme instance MinIO que le bucket dev (docker-compose.dev.yml), bucket
# distinct "story-tide-e2e" (mc mb --ignore-existing dans minio-setup).
S3_ENDPOINT="localhost"
S3_PORT=9000
S3_USE_SSL=false
S3_REGION="us-east-1"
S3_ACCESS_KEY="story_tide"
S3_SECRET_KEY="change-me-story-tide"
S3_BUCKET="story-tide-e2e"
